{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "paths": {
      "@loomstack/core": ["./packages/core/src/index.ts"],
      "@loomstack/runtime": ["./packages/runtime/src/index.ts"],
      "@loomstack/generator": ["./packages/generator/src/index.ts"],
      "@loomstack/verifier": ["./packages/verifier/src/index.ts"],
      "@loomstack/react": ["./packages/react-adapter/src/index.tsx"],
      "@loomstack/koa": ["./packages/koa-adapter/src/index.ts"],
      "@loomstack/postgres": ["./packages/postgres-adapter/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx", "vitest.config.ts"],
  "exclude": ["**/dist", "**/node_modules"]
}
